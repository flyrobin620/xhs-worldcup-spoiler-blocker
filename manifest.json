{
  "manifest_version": 3,
  "name": "小红书世界杯防剧透 / XHS World Cup Spoiler Blocker",
  "version": "1.1.0",
  "description": "Hide match scores and result spoilers on Xiaohongshu's 2026 World Cup pages and replay notes.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "世界杯防剧透 / XHS World Cup Spoiler Blocker",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.xiaohongshu.com/*",
        "https://xiaohongshu.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_start"
    }
  ]
}
